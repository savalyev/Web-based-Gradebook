# Server
PORT=4000
NODE_ENV=development

# CORS / client origin (Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL=postgres://gradebook:gradebook@localhost:5432/gradebook

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# File storage (relative to repo root)
UPLOAD_DIR=../uploads
MAX_UPLOAD_MB=20
