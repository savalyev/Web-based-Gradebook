# ---- Production environment (copy to server/.env on the server) ----
NODE_ENV=production
PORT=4000

# Your public site origin (used for CORS; with single-origin serving it
# matches the site itself). Use https.
CLIENT_ORIGIN=https://your-domain.com

# PostgreSQL connection (create role/db on the server first)
DATABASE_URL=postgres://gradebook:STRONG_DB_PASSWORD@localhost:5432/gradebook

# Auth — MUST be a long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=PUT_A_LONG_RANDOM_SECRET_HERE
JWT_EXPIRES_IN=7d

# File storage (absolute path recommended in production)
UPLOAD_DIR=/var/www/gradebook/uploads
MAX_UPLOAD_MB=20

# Serve the built SPA from Express (single origin). Path to client/dist.
CLIENT_DIST=/var/www/gradebook/client/dist

# Number of reverse proxies in front of the app (nginx = 1).
# Required so secure cookies and login rate-limiting see the real client IP.
TRUST_PROXY=1
